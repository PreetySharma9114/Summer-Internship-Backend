{
  "info": {
    "name": "Summer Internship Backend",
    "_postman_id": "summer-internship-backend",
    "description": "Complete Postman collection for Summer Internship Backend. Includes Register, Verify OTP, Resend OTP, Create Password, Login, Profile setup, Campaigns management (including Update and Delete), Applications (including Accept, Reject, and Cancel/Delete), and File uploads.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "campaignId",
      "value": ""
    },
    {
      "key": "applicationId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.data && response.data.id) {",
                  "    pm.collectionVariables.set(\"userId\", response.data.id);",
                  "    console.log(\"Saved userId:\", response.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jakshay12@gmail.com\",\n  \"role\": \"INFLUENCER\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register",
            "description": "Register a new user (role: \"INFLUENCER\" or \"BRAND\"). Generates an OTP and saves the `userId` in collection variables."
          },
          "response": []
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{userId}}\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/verify-otp",
            "description": "Verify the email using the OTP received. Pass the `id` from the register response."
          },
          "response": []
        },
        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{userId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/resend-otp",
            "description": "Resends a new OTP to the user."
          },
          "response": []
        },
        {
          "name": "Create Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{userId}}\",\n  \"password\": \"Jakshay@1\",\n  \"confirmPassword\": \"Jakshay@1\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/create-password",
            "description": "Set a new password. The password must be at least 8 characters long and contain at least one uppercase, lowercase, number, and special character."
          },
          "response": []
        },
        {
          "name": "Login Brand",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.data && response.data.token) {",
                  "    pm.collectionVariables.set(\"token\", response.data.token);",
                  "    console.log(\"Saved Brand JWT token:\", response.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jakshay22@gmail.com\",\n  \"password\": \"Jakshay@1\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Authenticate Brand credentials. Saves the returned JWT `token` in collection variables."
          },
          "response": []
        },
        {
          "name": "Login Influencer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.data && response.data.token) {",
                  "    pm.collectionVariables.set(\"token\", response.data.token);",
                  "    console.log(\"Saved Influencer JWT token:\", response.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jakshay12@gmail.com\",\n  \"password\": \"Jakshay@1\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Authenticate Influencer credentials. Saves the returned JWT `token` in collection variables."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Complete Influencer Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Akshay J\",\n  \"username\": \"jakshay12\",\n  \"bio\": \"Lifestyle and tech creator.\",\n  \"niche\": \"Technology\",\n  \"instagramUsername\": \"jakshay_ig\",\n  \"youtubeUsername\": \"jakshay_yt\",\n  \"instagramFollowers\": 10000,\n  \"youtubeFollowers\": 5000,\n  \"profileImage\": \"https://images.unsplash.com/photo-1534528741775-53994a69daeb\"\n}"
            },
            "url": "{{baseUrl}}/api/profile/influencer",
            "description": "Completes or updates the profile details for an INFLUENCER user."
          },
          "response": []
        },
        {
          "name": "Complete Brand Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"brandName\": \"Acme Apparel\",\n  \"website\": \"https://acmeapparel.example.com\",\n  \"description\": \"Premium activewear for modern athletes.\",\n  \"industry\": \"FASHION\",\n  \"instagramUsername\": \"acme_apparel\",\n  \"logo\": \"https://example.com/acme_logo.png\"\n}"
            },
            "url": "{{baseUrl}}/api/profile/brand",
            "description": "Completes or updates the profile details for a BRAND user."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Campaign",
      "item": [
        {
          "name": "Create Campaign",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.data && response.data._id) {",
                  "    pm.collectionVariables.set(\"campaignId\", response.data._id);",
                  "    console.log(\"Saved campaignId:\", response.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Fashion Summer Campaign\",\n  \"description\": \"Promote our summer collection on social media\",\n  \"category\": \"FASHION\",\n  \"platforms\": [\"INSTAGRAM\", \"YOUTUBE\"],\n  \"budgetPerInfluencer\": 5000,\n  \"totalSlots\": 10,\n  \"startDate\": \"2026-06-10\",\n  \"endDate\": \"2026-07-10\"\n}"
            },
            "url": "{{baseUrl}}/api/campaigns",
            "description": "Creates a new campaign. Must be authenticated as a BRAND. Saves the created campaign ID to collection variables."
          },
          "response": []
        },
        {
          "name": "Get All Campaigns",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/campaigns"
          },
          "response": []
        },
        {
          "name": "Get My Campaigns",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/campaigns/my"
          },
          "response": []
        },
        {
          "name": "Update Campaign",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Fashion Summer Campaign\",\n  \"budgetPerInfluencer\": 6000\n}"
            },
            "url": "{{baseUrl}}/api/campaigns/{{campaignId}}",
            "description": "Update details of an existing campaign. Must be authenticated as the Brand who created the campaign."
          },
          "response": []
        },
        {
          "name": "Delete Campaign",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/campaigns/{{campaignId}}",
            "description": "Delete a campaign by ID. Must be authenticated as the Brand who created the campaign."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "Apply To Campaign",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.data && response.data._id) {",
                  "    pm.collectionVariables.set(\"applicationId\", response.data._id);",
                  "    console.log(\"Saved applicationId:\", response.data._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/campaigns/{{campaignId}}/apply"
          },
          "response": []
        },
        {
          "name": "Get Campaign Applications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/campaigns/{{campaignId}}/applications"
          },
          "response": []
        },
        {
          "name": "Get My Applications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/applications/my"
          },
          "response": []
        },
        {
          "name": "Accept Application",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACCEPTED\"\n}"
            },
            "url": "{{baseUrl}}/api/applications/{{applicationId}}/status"
          },
          "response": []
        },
        {
          "name": "Reject Application",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"REJECTED\"\n}"
            },
            "url": "{{baseUrl}}/api/applications/{{applicationId}}/status"
          },
          "response": []
        },
        {
          "name": "Cancel/Delete Application",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/applications/{{applicationId}}",
            "description": "Cancel or delete an application. Must be the Influencer who applied."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Uploads",
      "item": [
        {
          "name": "Upload File",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": "{{baseUrl}}/api/upload",
            "description": "Upload an image or document. Requires multipart form-data with the key `file`."
          },
          "response": []
        }
      ]
    }
  ]
}